<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>三大法人持股變化追蹤</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:"PingFang TC","Microsoft JhengHei","Segoe UI",Arial,sans-serif;
     background:#f0f2f5;color:#1a1a2e;line-height:1.55}
header{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);
       color:#fff;padding:18px 32px;display:flex;align-items:center;justify-content:space-between;gap:16px}
header h1{font-size:20px;font-weight:700;letter-spacing:.02em}
header .meta{opacity:.65;font-size:12px;text-align:right;line-height:1.8}
.container{max-width:1400px;margin:20px auto;padding:0 14px}

/* ── chips ── */
.chips{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.chip{background:#fff;border-radius:10px;padding:12px 18px;
      box-shadow:0 2px 8px rgba(0,0,0,.06);flex:1;min-width:110px}
.chip .val{font-size:22px;font-weight:800;color:#4361ee}
.chip .lbl{font-size:12px;color:#888;margin-top:2px}

/* ── period bar ── */
.period-bar{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.period-bar label{font-size:13px;font-weight:600;color:#555;margin-right:4px}
.pbtn{padding:7px 18px;border-radius:20px;border:1.5px solid #d0d5dd;
      background:#fff;cursor:pointer;font-size:13px;font-weight:600;
      color:#555;transition:.18s}
.pbtn.active{background:#4361ee;color:#fff;border-color:#4361ee}
.pbtn:hover:not(.active){border-color:#4361ee;color:#4361ee}
.custom-range{display:none;gap:6px;align-items:center}
.custom-range.show{display:flex}
.custom-range input{padding:6px 10px;border:1.5px solid #d0d5dd;border-radius:8px;
                    font-size:13px;width:130px;outline:none}
.custom-range input:focus{border-color:#4361ee}
.custom-range button{padding:6px 14px;border-radius:8px;border:none;
                     background:#4361ee;color:#fff;cursor:pointer;font-size:13px}

/* ── main tabs ── */
.tabs{display:flex;gap:4px;margin-bottom:0;border-bottom:2px solid #e2e8f0}
.tab{padding:9px 20px;border:none;background:none;cursor:pointer;
     font-size:14px;font-weight:600;color:#777;border-bottom:2px solid transparent;
     margin-bottom:-2px;transition:.18s}
.tab.active{color:#4361ee;border-bottom-color:#4361ee}
.tab:hover:not(.active){color:#4361ee}

/* ── card ── */
.card{background:#fff;border-radius:12px;padding:20px;
      box-shadow:0 2px 12px rgba(0,0,0,.06);margin-top:16px}

/* ── filter row ── */
.filter-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
.filter-row input[type=text]{padding:7px 12px;border:1.5px solid #d0d5dd;border-radius:8px;
                              font-size:13px;width:200px;outline:none}
.filter-row input:focus{border-color:#4361ee}
.filter-row select{padding:7px 12px;border:1.5px solid #d0d5dd;border-radius:8px;
                   font-size:13px;outline:none;background:#fff;cursor:pointer}
.filter-row select:focus{border-color:#4361ee}
.filter-row .badge-filter{padding:6px 14px;border-radius:20px;border:1.5px solid #d0d5dd;
                          background:#fff;cursor:pointer;font-size:12px;font-weight:600;
                          color:#555;transition:.18s}
.filter-row .badge-filter.active{background:#f0f4ff;border-color:#4361ee;color:#4361ee}

/* ── table ── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px;min-width:900px}
thead th{background:#f7f8fc;padding:9px 12px;text-align:left;font-weight:700;
         border-bottom:2px solid #e2e8f0;cursor:pointer;user-select:none;
         white-space:nowrap;font-size:12px;letter-spacing:.03em}
thead th:hover{background:#eef0f8}
thead th.sort-asc::after{content:" ▲";opacity:.6;font-size:10px}
thead th.sort-desc::after{content:" ▼";opacity:.6;font-size:10px}
thead th.right{text-align:right}
tbody tr{border-bottom:1px solid #f0f2f5;transition:background .12s}
tbody tr:hover{background:#f5f7ff}
td{padding:9px 12px;white-space:nowrap}
td.right{text-align:right;font-variant-numeric:tabular-nums}
td.ticker{font-weight:700;color:#16213e}
td.name{color:#444;max-width:120px;overflow:hidden;text-overflow:ellipsis}

/* ── value coloring ── */
.up{color:#dc2626;font-weight:700}
.dn{color:#16a34a;font-weight:700}
.neu{color:#888}

/* ── score badge ── */
.score{display:inline-block;width:22px;height:22px;border-radius:50%;
       text-align:center;line-height:22px;font-size:11px;font-weight:800}
.score-5{background:#7f1d1d;color:#fff}
.score-4{background:#dc2626;color:#fff}
.score-3{background:#f97316;color:#fff}
.score-2{background:#fbbf24;color:#1a1a2e}
.score-1{background:#d1fae5;color:#065f46}
.score-0{background:#f0f2f5;color:#aaa}

/* ── holding pct bar ── */
.pct-bar{display:flex;align-items:center;gap:6px}
.pct-bar .bar-bg{background:#e9ecef;border-radius:4px;height:6px;width:60px;flex-shrink:0}
.pct-bar .bar-fill{background:linear-gradient(90deg,#4361ee,#7b97ff);border-radius:4px;height:6px}

/* ── panel ── */
.panel{display:none}
.panel.active{display:block}
.empty{text-align:center;padding:50px;color:#aaa}
.loading{text-align:center;padding:60px;color:#888;font-size:16px}
.error-msg{background:#fff1f2;color:#991b1b;border-radius:8px;padding:16px 20px;margin-top:16px}

/* ── instruction ── */
.instr{background:#eff6ff;border-left:4px solid #4361ee;border-radius:6px;
       padding:14px 18px;margin-bottom:16px;font-size:13px;line-height:1.8;color:#1e3a5f}
.instr code{background:#dde9ff;border-radius:4px;padding:1px 6px;font-family:monospace;font-size:12px}

@media(max-width:700px){
  header{flex-direction:column;align-items:flex-start}
  .chips .chip{min-width:45%}
}
</style>
</head>
<body>
<header>
  <div>
    <h1>三大法人持股變化追蹤</h1>
    <div style="opacity:.6;font-size:12px;margin-top:4px">外資・投信・自營商 買賣超 &amp; 外資持股比率</div>
  </div>
  <div class="meta" id="meta">－</div>
</header>

<div class="container">

  <!-- 期間選擇 -->
  <div style="margin-top:16px">
    <div class="period-bar">
      <label>查詢區間：</label>
      <button class="pbtn" data-n="1" onclick="setPeriod(this)">當日</button>
      <button class="pbtn" data-n="2" onclick="setPeriod(this)">近 2 日</button>
      <button class="pbtn active" data-n="5" onclick="setPeriod(this)">近 5 日</button>
      <button class="pbtn" data-n="10" onclick="setPeriod(this)">近 10 日</button>
      <button class="pbtn" data-n="20" onclick="setPeriod(this)">近 20 日</button>
      <button class="pbtn" data-n="0" onclick="setPeriod(this)">自訂</button>
      <div class="custom-range" id="customRange">
        <input type="date" id="dateFrom" placeholder="開始日期">
        <span>～</span>
        <input type="date" id="dateTo" placeholder="結束日期">
        <button onclick="applyCustom()">套用</button>
      </div>
    </div>
  </div>

  <!-- 概要 chips -->
  <div class="chips" id="chips">
    <div class="chip"><div class="val" id="c-total">—</div><div class="lbl">追蹤股票數</div></div>
    <div class="chip"><div class="val" id="c-foreign-buy">—</div><div class="lbl">外資買超股數</div></div>
    <div class="chip"><div class="val" id="c-trust-buy">—</div><div class="lbl">投信買超股數</div></div>
    <div class="chip"><div class="val" id="c-strategy">—</div><div class="lbl">策略評分 ≥ 3 支數</div></div>
  </div>

  <!-- 主 tab -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('all')">全部法人合計</button>
    <button class="tab" onclick="switchTab('foreign')">外資</button>
    <button class="tab" onclick="switchTab('trust')">投信</button>
    <button class="tab" onclick="switchTab('dealer')">自營商</button>
    <button class="tab" onclick="switchTab('holding')">外資持股比率</button>
    <button class="tab" onclick="switchTab('strategy')">策略篩選</button>
  </div>

  <div id="loading" class="loading" style="margin-top:20px">⏳ 載入資料中…</div>
  <div id="err" class="error-msg" style="display:none"></div>

  <!-- ── 全部法人合計 ── -->
  <div id="panel-all" class="panel card">
    <div class="filter-row">
      <input type="text" id="q-all" placeholder="搜尋代號或名稱…" oninput="renderAll()">
      <select id="dir-all" onchange="renderAll()">
        <option value="">全部方向</option>
        <option value="buy">買超</option>
        <option value="sell">賣超</option>
      </select>
    </div>
    <div class="tbl-wrap"><table id="tbl-all">
      <thead><tr>
        <th onclick="sortBy('ticker','all')" class="right">代號</th>
        <th onclick="sortBy('name','all')">名稱</th>
        <th onclick="sortBy('close','all')" class="right">收盤</th>
        <th onclick="sortBy('change','all')" class="right">漲跌</th>
        <th onclick="sortBy('change_pct','all')" class="right">漲跌幅</th>
        <th onclick="sortBy('foreign','all')" class="right">外資(張)</th>
        <th onclick="sortBy('trust','all')" class="right">投信(張)</th>
        <th onclick="sortBy('dealer','all')" class="right">自營(張)</th>
        <th onclick="sortBy('total','all')" class="right">合計(張)</th>
        <th onclick="sortBy('total_amount','all')" class="right">買超金額</th>
        <th onclick="sortBy('holding_pct','all')" class="right">外資持股%</th>
        <th onclick="sortBy('chg_1w','all')" class="right">週變化%</th>
      </tr></thead>
      <tbody id="body-all"></tbody>
    </table></div>
  </div>

  <!-- ── 外資 ── -->
  <div id="panel-foreign" class="panel card">
    <div class="filter-row">
      <input type="text" id="q-foreign" placeholder="搜尋代號或名稱…" oninput="renderForeign()">
      <select id="dir-foreign" onchange="renderForeign()">
        <option value="">全部方向</option>
        <option value="buy">買超</option>
        <option value="sell">賣超</option>
      </select>
    </div>
    <div class="tbl-wrap"><table id="tbl-foreign">
      <thead><tr>
        <th onclick="sortBy('ticker','foreign')" class="right">代號</th>
        <th onclick="sortBy('name','foreign')">名稱</th>
        <th onclick="sortBy('close','foreign')" class="right">收盤</th>
        <th onclick="sortBy('change','foreign')" class="right">漲跌</th>
        <th onclick="sortBy('change_pct','foreign')" class="right">漲跌幅</th>
        <th onclick="sortBy('foreign','foreign')" class="right">外資買超(張)</th>
        <th onclick="sortBy('foreign_amount','foreign')" class="right">買超金額</th>
        <th onclick="sortBy('holding_pct','foreign')" class="right">外資持股%</th>
        <th onclick="sortBy('chg_1w','foreign')" class="right">週變化%</th>
        <th onclick="sortBy('chg_3w','foreign')" class="right">三週累計%</th>
      </tr></thead>
      <tbody id="body-foreign"></tbody>
    </table></div>
  </div>

  <!-- ── 投信 ── -->
  <div id="panel-trust" class="panel card">
    <div class="filter-row">
      <input type="text" id="q-trust" placeholder="搜尋代號或名稱…" oninput="renderTrust()">
      <select id="dir-trust" onchange="renderTrust()">
        <option value="">全部方向</option>
        <option value="buy">買超</option>
        <option value="sell">賣超</option>
      </select>
    </div>
    <div class="tbl-wrap"><table id="tbl-trust">
      <thead><tr>
        <th onclick="sortBy('ticker','trust')" class="right">代號</th>
        <th onclick="sortBy('name','trust')">名稱</th>
        <th onclick="sortBy('close','trust')" class="right">收盤</th>
        <th onclick="sortBy('change','trust')" class="right">漲跌</th>
        <th onclick="sortBy('change_pct','trust')" class="right">漲跌幅</th>
        <th onclick="sortBy('trust','trust')" class="right">投信買超(張)</th>
        <th onclick="sortBy('trust_amount','trust')" class="right">買超金額</th>
        <th onclick="sortBy('foreign','trust')" class="right">外資(張)</th>
        <th onclick="sortBy('total','trust')" class="right">三大合計(張)</th>
      </tr></thead>
      <tbody id="body-trust"></tbody>
    </table></div>
  </div>

  <!-- ── 自營商 ── -->
  <div id="panel-dealer" class="panel card">
    <div class="filter-row">
      <input type="text" id="q-dealer" placeholder="搜尋代號或名稱…" oninput="renderDealer()">
      <select id="dir-dealer" onchange="renderDealer()">
        <option value="">全部方向</option>
        <option value="buy">買超</option>
        <option value="sell">賣超</option>
      </select>
    </div>
    <div class="tbl-wrap"><table id="tbl-dealer">
      <thead><tr>
        <th onclick="sortBy('ticker','dealer')" class="right">代號</th>
        <th onclick="sortBy('name','dealer')">名稱</th>
        <th onclick="sortBy('close','dealer')" class="right">收盤</th>
        <th onclick="sortBy('change','dealer')" class="right">漲跌</th>
        <th onclick="sortBy('change_pct','dealer')" class="right">漲跌幅</th>
        <th onclick="sortBy('dealer','dealer')" class="right">自營買超(張)</th>
        <th onclick="sortBy('dealer_amount','dealer')" class="right">買超金額</th>
        <th onclick="sortBy('foreign','dealer')" class="right">外資(張)</th>
        <th onclick="sortBy('total','dealer')" class="right">三大合計(張)</th>
      </tr></thead>
      <tbody id="body-dealer"></tbody>
    </table></div>
  </div>

  <!-- ── 外資持股比率 ── -->
  <div id="panel-holding" class="panel card">
    <div class="filter-row">
      <input type="text" id="q-holding" placeholder="搜尋代號或名稱…" oninput="renderHolding()">
      <select id="dir-holding" onchange="renderHolding()">
        <option value="">全部方向</option>
        <option value="buy">週增加</option>
        <option value="sell">週減少</option>
      </select>
      <button class="badge-filter" id="btn-sig" onclick="toggleSig()">僅顯示顯著變化 ≥ 0.5%</button>
    </div>
    <div class="tbl-wrap"><table id="tbl-holding">
      <thead><tr>
        <th onclick="sortBy('ticker','holding')" class="right">代號</th>
        <th onclick="sortBy('name','holding')">名稱</th>
        <th onclick="sortBy('holding_pct','holding')" class="right">外資持股%</th>
        <th class="right">持股比率圖</th>
        <th onclick="sortBy('chg_1w','holding')" class="right">週變化%</th>
        <th onclick="sortBy('chg_3w','holding')" class="right">三週累計%</th>
      </tr></thead>
      <tbody id="body-holding"></tbody>
    </table></div>
  </div>

  <!-- ── 策略篩選 ── -->
  <div id="panel-strategy" class="panel card">
    <div class="instr">
      <strong>策略篩選條件</strong>（步驟二量化濾網）<br>
      <strong>評分方式：</strong>
      外資週持股比率 ≥ 0.8% → +2分 | ≥ 0.3% → +1分；
      外資期間買超 &gt; 0 → +1分；
      投信期間買超 &gt; 0 → +1分；
      三大合計買超 &gt; 0 → +1分<br>
      <strong>使用方式：</strong> 先執行 <code>python three_laws_tracker.py backfill --days 20 --holding</code>，
      再執行 <code>python three_laws_tracker.py build</code> 生成儀表板資料。
    </div>
    <div class="filter-row">
      <input type="text" id="q-strategy" placeholder="搜尋代號或名稱…" oninput="renderStrategy()">
      <select id="minscore" onchange="renderStrategy()">
        <option value="0">全部評分</option>
        <option value="3" selected>評分 ≥ 3</option>
        <option value="4">評分 ≥ 4</option>
        <option value="5">滿分 5</option>
      </select>
      <select id="dir-strategy" onchange="renderStrategy()">
        <option value="">全部方向</option>
        <option value="buy">外資買超</option>
        <option value="sell">外資賣超</option>
      </select>
    </div>
    <div class="tbl-wrap"><table id="tbl-strategy">
      <thead><tr>
        <th onclick="sortBy('score','strategy')" class="right">評分</th>
        <th onclick="sortBy('ticker','strategy')" class="right">代號</th>
        <th onclick="sortBy('name','strategy')">名稱</th>
        <th onclick="sortBy('chg_1w','strategy')" class="right">外資週變化%</th>
        <th onclick="sortBy('chg_3w','strategy')" class="right">三週累計%</th>
        <th onclick="sortBy('foreign','strategy')" class="right">外資(張)</th>
        <th onclick="sortBy('trust','strategy')" class="right">投信(張)</th>
        <th onclick="sortBy('dealer','strategy')" class="right">自營(張)</th>
        <th onclick="sortBy('total','strategy')" class="right">合計(張)</th>
        <th onclick="sortBy('holding_pct','strategy')" class="right">外資持股%</th>
      </tr></thead>
      <tbody id="body-strategy"></tbody>
    </table></div>
  </div>

</div><!-- /container -->

<script>
// ─── 狀態 ───────────────────────────────────────────────────────────────────
let G = null;          // 全域資料
let period = 5;        // 目前期間 (2/5/10/20/0=自訂)
let customDates = [];  // 自訂日期清單
let activeTab = 'all';
let sortState = {};    // {tabId: {col, dir}}
let sigOnly = false;

// ─── 資料載入 ────────────────────────────────────────────────────────────────
async function loadData() {
  // 獨立模式：build 指令已將資料內嵌於此檔案
  if (window.__DASHBOARD_DATA__) {
    G = window.__DASHBOARD_DATA__;
    document.getElementById('loading').style.display = 'none';
    initMeta();
    renderActive();
    return;
  }
  // 開發模式：從 JSON 檔案讀取（需 web server）
  try {
    const resp = await fetch('data/three_laws/dashboard.json?t=' + Date.now());
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    G = await resp.json();
    document.getElementById('loading').style.display = 'none';
    initMeta();
    renderActive();
  } catch(e) {
    document.getElementById('loading').style.display = 'none';
    const el = document.getElementById('err');
    el.style.display = 'block';
    el.innerHTML = `<strong>無法載入資料</strong>：${e.message}<br><br>
      請先執行以下指令產生資料：<br>
      <code style="background:#ffe4e6;padding:6px 10px;border-radius:4px;display:inline-block;margin-top:8px">
      python three_laws_tracker.py fetch --holding<br>
      python three_laws_tracker.py build
      </code>`;
  }
}

// ─── 期間解析 ────────────────────────────────────────────────────────────────
function getDates() {
  if (!G) return [];
  const all = G.trading_dates || [];
  if (period === 0) return customDates;
  return all.slice(-period);
}

function getKey(p) {
  const n = period === 0 ? 'custom' : period;
  return `${p}_${n}d`;
}

function getVal(stock, prefix) {
  if (period === 0) {
    // 自訂：動態計算不在 JSON 中，fallback 到最近值
    return stock[`${prefix}_20d`] || 0;
  }
  const map = {1:'1d', 2:'2d', 5:'5d', 10:'10d', 20:'20d'};
  const suf = map[period] || '5d';
  return stock[`${prefix}_${suf}`] || 0;
}

// ─── Meta ────────────────────────────────────────────────────────────────────
function initMeta() {
  const d = G.trading_dates || [];
  const h = G.holding_dates || [];
  document.getElementById('meta').innerHTML =
    `資料日期：${d[d.length-1]||'—'}<br>` +
    `持股日期：${h[h.length-1]||'—'}<br>` +
    `更新：${(G.generated_at||'').replace('T',' ')}`;
  updateChips();
}

function updateChips() {
  if (!G) return;
  const stocks = G.stocks || [];
  let fBuy = 0, tBuy = 0, sig = 0;
  for (const s of stocks) {
    const f = getVal(s,'foreign'), t = getVal(s,'trust');
    if (f > 0) fBuy++;
    if (t > 0) tBuy++;
    if ((s.score || 0) >= 3) sig++;
  }
  document.getElementById('c-total').textContent = stocks.length.toLocaleString();
  document.getElementById('c-foreign-buy').textContent = fBuy.toLocaleString();
  document.getElementById('c-trust-buy').textContent = tBuy.toLocaleString();
  document.getElementById('c-strategy').textContent = sig.toLocaleString();
}

// ─── 期間切換 ────────────────────────────────────────────────────────────────
function setPeriod(btn) {
  document.querySelectorAll('.pbtn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  period = parseInt(btn.dataset.n);
  const cr = document.getElementById('customRange');
  cr.classList.toggle('show', period === 0);
  if (period !== 0) {
    updateChips();
    renderActive();
  }
}

function applyCustom() {
  const from = document.getElementById('dateFrom').value;
  const to   = document.getElementById('dateTo').value;
  if (!from || !to || !G) return;
  customDates = (G.trading_dates || []).filter(d => d >= from && d <= to);
  updateChips();
  renderActive();
}

// ─── Tab 切換 ────────────────────────────────────────────────────────────────
function switchTab(name) {
  activeTab = name;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  renderActive();
}

function renderActive() {
  if (!G) return;
  const fn = {all:renderAll, foreign:renderForeign, trust:renderTrust,
              dealer:renderDealer, holding:renderHolding, strategy:renderStrategy};
  (fn[activeTab] || renderAll)();
}

// ─── 排序 ────────────────────────────────────────────────────────────────────
function sortBy(col, tab) {
  const st = sortState[tab] || {};
  if (st.col === col) st.dir = st.dir === 'desc' ? 'asc' : 'desc';
  else { st.col = col; st.dir = 'desc'; }
  sortState[tab] = st;
  // 更新 header UI
  const tbl = document.getElementById('tbl-' + tab);
  tbl.querySelectorAll('th').forEach(th => {
    th.classList.remove('sort-asc','sort-desc');
    if (th.getAttribute('onclick') === `sortBy('${col}','${tab}')`)
      th.classList.add(st.dir === 'asc' ? 'sort-asc' : 'sort-desc');
  });
  renderActive();
}

function applySort(arr, tab, defaultCol, defaultDir) {
  const st = sortState[tab] || {col: defaultCol, dir: defaultDir || 'desc'};
  const {col, dir} = st;
  return [...arr].sort((a,b) => {
    let va = a[col] ?? 0, vb = b[col] ?? 0;
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    if (va < vb) return dir === 'asc' ? -1 : 1;
    if (va > vb) return dir === 'asc' ? 1 : -1;
    return 0;
  });
}

// ─── 工具函式 ────────────────────────────────────────────────────────────────
function numCell(v, cls='') {
  const color = v > 0 ? 'up' : v < 0 ? 'dn' : 'neu';
  return `<td class="right ${color} ${cls}">${v > 0 ? '+' : ''}${v.toLocaleString()}</td>`;
}

function pctCell(v) {
  const color = v > 0 ? 'up' : v < 0 ? 'dn' : 'neu';
  return `<td class="right ${color}">${v > 0 ? '+' : ''}${v.toFixed(2)}%</td>`;
}

function priceCell(s) {
  if (!s.close) return '<td class="right neu">—</td>';
  return `<td class="right">${s.close.toFixed(2)}</td>`;
}

function changeCells(s) {
  if (!s.close) return '<td class="right neu">—</td><td class="right neu">—</td>';
  const color = s.change > 0 ? 'up' : s.change < 0 ? 'dn' : 'neu';
  const chg = s.change > 0 ? `+${s.change.toFixed(2)}` : s.change.toFixed(2);
  const pct = s.change_pct > 0 ? `+${s.change_pct.toFixed(2)}%` : `${s.change_pct.toFixed(2)}%`;
  return `<td class="right ${color}">${chg}</td><td class="right ${color}">${pct}</td>`;
}

function amountCell(net, close) {
  // 買超金額（萬元）= 張數 × 收盤價 × 1000股 ÷ 10000
  if (!close) return '<td class="right neu">—</td>';
  const amt = Math.round(net * close / 10);
  const color = amt > 0 ? 'up' : amt < 0 ? 'dn' : 'neu';
  const abs = Math.abs(amt);
  const disp = abs >= 10000 ? `${(amt/10000).toFixed(1)}億` : `${amt.toLocaleString()}萬`;
  return `<td class="right ${color}">${disp}</td>`;
}

function filterStocks(tabId) {
  const q = (document.getElementById('q-' + tabId)?.value || '').trim().toLowerCase();
  const dir = document.getElementById('dir-' + tabId)?.value || '';
  return (G.stocks || []).filter(s => {
    if (q && !s.ticker.includes(q.toUpperCase()) && !s.name.toLowerCase().includes(q)) return false;
    const f = getVal(s,'foreign');
    if (dir === 'buy' && f <= 0) return false;
    if (dir === 'sell' && f >= 0) return false;
    return true;
  });
}

function scoreClass(n) {
  return `score score-${Math.min(n,5)}`;
}

// ─── 各 Tab 渲染 ─────────────────────────────────────────────────────────────

function renderAll() {
  if (!G) return;
  let rows = filterStocks('all').map(s => ({
    ...s,
    foreign: getVal(s,'foreign'),
    trust:   getVal(s,'trust'),
    dealer:  getVal(s,'dealer'),
    total:   getVal(s,'total'),
    total_amount: Math.round(getVal(s,'total') * (s.close||0) / 10),
  }));
  rows = applySort(rows, 'all', 'total');
  const body = document.getElementById('body-all');
  body.innerHTML = rows.map(s => `<tr>
    <td class="right ticker">${s.ticker}</td>
    <td class="name">${s.name}</td>
    ${priceCell(s)} ${changeCells(s)}
    ${numCell(s.foreign)} ${numCell(s.trust)} ${numCell(s.dealer)} ${numCell(s.total)}
    ${amountCell(s.total, s.close)}
    <td class="right">${s.holding_pct.toFixed(2)}%</td>
    ${pctCell(s.chg_1w)}
  </tr>`).join('');
}

function renderForeign() {
  if (!G) return;
  let rows = filterStocks('foreign').map(s => ({
    ...s,
    foreign: getVal(s,'foreign'),
    foreign_amount: Math.round(getVal(s,'foreign') * (s.close||0) / 10),
  }));
  rows = applySort(rows, 'foreign', 'foreign');
  document.getElementById('body-foreign').innerHTML = rows.map(s => `<tr>
    <td class="right ticker">${s.ticker}</td>
    <td class="name">${s.name}</td>
    ${priceCell(s)} ${changeCells(s)}
    ${numCell(s.foreign)}
    ${amountCell(s.foreign, s.close)}
    <td class="right">${s.holding_pct.toFixed(2)}%</td>
    ${pctCell(s.chg_1w)} ${pctCell(s.chg_3w)}
  </tr>`).join('');
}

function renderTrust() {
  if (!G) return;
  let rows = (G.stocks || []).filter(s => {
    const q = (document.getElementById('q-trust')?.value || '').trim().toLowerCase();
    const dir = document.getElementById('dir-trust')?.value || '';
    if (q && !s.ticker.includes(q.toUpperCase()) && !s.name.toLowerCase().includes(q)) return false;
    const t = getVal(s,'trust');
    if (dir === 'buy' && t <= 0) return false;
    if (dir === 'sell' && t >= 0) return false;
    return true;
  }).map(s => ({...s,
    trust: getVal(s,'trust'), foreign: getVal(s,'foreign'), total: getVal(s,'total'),
    trust_amount: Math.round(getVal(s,'trust') * (s.close||0) / 10),
  }));
  rows = applySort(rows, 'trust', 'trust');
  document.getElementById('body-trust').innerHTML = rows.map(s => `<tr>
    <td class="right ticker">${s.ticker}</td>
    <td class="name">${s.name}</td>
    ${priceCell(s)} ${changeCells(s)}
    ${numCell(s.trust)}
    ${amountCell(s.trust, s.close)}
    ${numCell(s.foreign)} ${numCell(s.total)}
  </tr>`).join('');
}

function renderDealer() {
  if (!G) return;
  let rows = (G.stocks || []).filter(s => {
    const q = (document.getElementById('q-dealer')?.value || '').trim().toLowerCase();
    const dir = document.getElementById('dir-dealer')?.value || '';
    if (q && !s.ticker.includes(q.toUpperCase()) && !s.name.toLowerCase().includes(q)) return false;
    const d = getVal(s,'dealer');
    if (dir === 'buy' && d <= 0) return false;
    if (dir === 'sell' && d >= 0) return false;
    return true;
  }).map(s => ({...s,
    dealer: getVal(s,'dealer'), foreign: getVal(s,'foreign'), total: getVal(s,'total'),
    dealer_amount: Math.round(getVal(s,'dealer') * (s.close||0) / 10),
  }));
  rows = applySort(rows, 'dealer', 'dealer');
  document.getElementById('body-dealer').innerHTML = rows.map(s => `<tr>
    <td class="right ticker">${s.ticker}</td>
    <td class="name">${s.name}</td>
    ${priceCell(s)} ${changeCells(s)}
    ${numCell(s.dealer)}
    ${amountCell(s.dealer, s.close)}
    ${numCell(s.foreign)} ${numCell(s.total)}
  </tr>`).join('');
}

function toggleSig() {
  sigOnly = !sigOnly;
  document.getElementById('btn-sig').classList.toggle('active', sigOnly);
  renderHolding();
}

function renderHolding() {
  if (!G) return;
  const q   = (document.getElementById('q-holding')?.value || '').trim().toLowerCase();
  const dir = document.getElementById('dir-holding')?.value || '';
  let rows = (G.stocks || []).filter(s => {
    if (!s.holding_pct && !s.chg_1w) return false;
    if (q && !s.ticker.includes(q.toUpperCase()) && !s.name.toLowerCase().includes(q)) return false;
    if (dir === 'buy'  && s.chg_1w <= 0) return false;
    if (dir === 'sell' && s.chg_1w >= 0) return false;
    if (sigOnly && Math.abs(s.chg_1w) < 0.5) return false;
    return true;
  });
  rows = applySort(rows, 'holding', 'chg_1w');
  document.getElementById('body-holding').innerHTML = rows.map(s => {
    const pct = Math.min(s.holding_pct, 100);
    return `<tr>
      <td class="right ticker">${s.ticker}</td>
      <td class="name">${s.name}</td>
      <td class="right">${s.holding_pct.toFixed(2)}%</td>
      <td><div class="pct-bar">
        <div class="bar-bg"><div class="bar-fill" style="width:${pct}%"></div></div>
        <span style="font-size:11px;color:#888">${pct.toFixed(0)}%</span>
      </div></td>
      ${pctCell(s.chg_1w)} ${pctCell(s.chg_3w)}
    </tr>`;
  }).join('');
}

function renderStrategy() {
  if (!G) return;
  const q       = (document.getElementById('q-strategy')?.value || '').trim().toLowerCase();
  const minScore= parseInt(document.getElementById('minscore')?.value || '0');
  const dir     = document.getElementById('dir-strategy')?.value || '';
  let rows = (G.stocks || []).filter(s => {
    if (q && !s.ticker.includes(q.toUpperCase()) && !s.name.toLowerCase().includes(q)) return false;
    if ((s.score || 0) < minScore) return false;
    const f = getVal(s,'foreign');
    if (dir === 'buy'  && f <= 0) return false;
    if (dir === 'sell' && f >= 0) return false;
    return true;
  }).map(s => ({
    ...s,
    foreign: getVal(s,'foreign'),
    trust:   getVal(s,'trust'),
    dealer:  getVal(s,'dealer'),
    total:   getVal(s,'total'),
  }));
  rows = applySort(rows, 'strategy', 'score');
  document.getElementById('body-strategy').innerHTML = rows.map(s => `<tr>
    <td class="right"><span class="${scoreClass(s.score)}">${s.score}</span></td>
    <td class="right ticker">${s.ticker}</td>
    <td class="name">${s.name}</td>
    ${pctCell(s.chg_1w)} ${pctCell(s.chg_3w)}
    ${numCell(s.foreign)} ${numCell(s.trust)} ${numCell(s.dealer)} ${numCell(s.total)}
    <td class="right">${s.holding_pct.toFixed(2)}%</td>
  </tr>`).join('');
}

// ─── 啟動 ────────────────────────────────────────────────────────────────────
loadData();
// 預設 panel 顯示
document.getElementById('panel-all').classList.add('active');
</script>
